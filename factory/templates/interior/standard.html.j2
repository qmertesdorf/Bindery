<!doctype html><html><head><meta charset="utf-8">
<link rel="stylesheet" href="interior.css">
{# Real per-page print margins for flowing prose. Overrides interior.css's
   `@page { margin: 0 }` (journals inset via fixed .page padding instead).
   browse honours CSS @page; a uniform 0.6in gives roomier standard comfort
   books while still clearing every KDP limit. MUST follow the <link>. #}
<style>@page { margin: 0.6in; }</style></head><body>

{# Standard read-through books rely on REAL per-page print margins (set by
   build_interior_pdf), so front matter and chapters flow freely — no fixed
   .page boxes, whose padding would double-inset over the print margin. Page
   breaks come from break-before. #}
<section class="title-page"><h1 class="book-title">{{ cfg.title }}</h1>
<p class="book-sub">{{ cfg.subtitle }}</p>
<p class="byline">{{ cfg.author }}</p></section>

{% if content.epigraph %}<section class="epigraph">
{% for line in content.epigraph.split('\n') if line.strip() %}<p>{{ line.strip() }}</p>{% endfor %}
</section>{% endif %}

<section class="preface"><h2 class="chapter-head">Preface</h2>
{% for para in content.preface.split('\n') if para.strip() %}<p class="body-para">{{ para.strip() }}</p>{% endfor %}
</section>

{% for ch in content.chapters %}
<section class="chapter"><h2 class="chapter-head">{{ ch.title }}</h2>
{% for para in ch.paragraphs %}<p class="body-para">{{ para }}</p>{% endfor %}
</section>
{% endfor %}

{% if content.readings %}
<section class="chapter readings-section"><h2 class="chapter-head">Words for the Hard Days</h2>
{% for r in content.readings %}<p class="body-para" style="text-indent:0;margin-bottom:0.28in">{{ r }}</p>{% endfor %}
</section>{% endif %}

{% include "interior/_matter.html.j2" %}

{% if content.closing_letter %}
<section class="chapter closing-letter"><h2 class="chapter-head">A Closing Letter</h2>
{% for para in content.closing_letter.split('\n') if para.strip() %}<p class="body-para">{{ para.strip() }}</p>{% endfor %}
</section>{% endif %}

</body></html>
