<!doctype html><html><head><meta charset="utf-8">
<style>{{ css|safe }}</style></head><body>
<div class="wrap">
  {% if not front_only %}
  <div class="back">
    <div class="backcard">
      <div class="backtitle">{{ cfg.title }}</div>
      <div class="backrule"></div>
      <p class="blurb">{{ blurb }}</p>
    </div>
  </div>
  {% endif %}
  <div class="front">
    <h1>{{ cfg.title }}</h1>
    <p class="sub">{{ cfg.subtitle }}</p>
    <div class="author">Written by {{ cfg.author }}{% if cfg.illustrator %}<br><span class="illus">Illustrated by {{ cfg.illustrator }}</span>{% endif %}</div>
  </div>
</div></body></html>
